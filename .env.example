# Root .env.example — used by docker-compose only.
# Each sub-repo (backend/, contracts/, veriflow-agent/) has its own .env.example.

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=aiwatt
MYSQL_USER=aiwatt
MYSQL_PASSWORD=aiwatt

# ── Redis ─────────────────────────────────────────────────────────────────────
# No extra config needed for default Redis — add AUTH password here if required
# REDIS_PASSWORD=
