# ══════════════════════════════════════════════════════════════════════════════
# AI WATT — Docker Compose environment
# Copy to .env and fill in real values.  Never commit .env
# ══════════════════════════════════════════════════════════════════════════════

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_PASSWORD=change-me-db-password

# ── Backend ───────────────────────────────────────────────────────────────────
APP_ENV=production

# Comma-separated allowed origins. Use * for testing; restrict to your domain in prod.
ALLOWED_ORIGINS=https://your-domain.com

JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# XDC Network (XDC_CHAIN_ID: 51 = Apothem testnet, 50 = XDC mainnet)
XDC_RPC_URL=https://erpc.apothem.network
XDC_CHAIN_ID=51

# Hot-wallet private key for on-chain writes. Leave 0x to disable.
VERIFLOW_SIGNER_PRIVATE_KEY=0x

# Contract proxy addresses (update after each deploy)
WATT_USD_PROXY_ADDRESS=0x974B2bd650c88D290469a471DeB1Ee6aC55AD2d9
SWATT_USD_PROXY_ADDRESS=0x08c14aCc5547f03fC523453e005A243C50A7aa94
MINT_ENGINE_PROXY_ADDRESS=0x37a1d3b072af3055993215DB82e3832dA2d10AEd
ASSET_REGISTRY_PROXY_ADDRESS=0x
OCNFT_PROXY_ADDRESS=0x
HEALTH_ATTESTATION_PROXY_ADDRESS=0x
LENDING_POOL_PROXY_ADDRESS=0x
WEV_QUEUE_PROXY_ADDRESS=0x

# External integrations (leave blank if unused)
BITGO_API_KEY=
PINATA_API_KEY=
KYC_PROVIDER_API_KEY=

# ── Frontend build args (baked into the static bundle at docker build time) ───
#
# VITE_API_URL: leave EMPTY so the browser uses relative paths (/api/v1/...)
# which nginx proxies to the backend container — no cross-origin issues.
# Set to a full URL only if backend is on a separate domain (e.g. https://api.aiwatt.io).
#
VITE_ENV=production
VITE_CHAIN_ID=51
VITE_RPC_URL=https://erpc.apothem.network
VITE_API_URL=
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

VITE_WATT_ADDRESS=0x974B2bd650c88D290469a471DeB1Ee6aC55AD2d9
VITE_SWATT_ADDRESS=0x08c14aCc5547f03fC523453e005A243C50A7aa94
VITE_MINT_ENGINE_ADDRESS=0x37a1d3b072af3055993215DB82e3832dA2d10AEd
VITE_LENDING_POOL_ADDRESS=0x
VITE_WEV_QUEUE_ADDRESS=0x
VITE_USDC_ADDRESS=0x6404e052B842fB1c82C1A404C7E02BE2A92A7970
VITE_USDT_ADDRESS=0x59828572B8ABEDa2A0f963ECC94b80Eee01bbA6c
