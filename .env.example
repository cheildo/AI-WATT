# AI WATT — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development

# ── Database (MySQL 8) ───────────────────────────────────────────────────────
DATABASE_URL=mysql://aiwatt:aiwatt@localhost:3306/aiwatt?parseTime=true

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── XDC Network ─────────────────────────────────────────────────────────────
# Testnet (Apothem, chainId: 51)
XDC_RPC_URL=https://erpc.apothem.network
# Mainnet (chainId: 50) — uncomment for production
# XDC_RPC_URL=https://erpc.xinfin.network

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# ── Veriflow Agent Signing ────────────────────────────────────────────────────
# Private key used by the backend to sign attestation transactions to XDC
VERIFLOW_SIGNER_PRIVATE_KEY=0x

# ── External Services ─────────────────────────────────────────────────────────
BITGO_API_KEY=
PINATA_API_KEY=
KYC_PROVIDER_API_KEY=

# ── Contracts (Hardhat) ───────────────────────────────────────────────────────
# Deployer private key for Hardhat scripts — Apothem testnet only
DEPLOYER_PRIVATE_KEY=0x
