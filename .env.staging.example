# ══════════════════════════════════════════════════════════════════════════════
# AI WATT — Staging environment (ai-watt VM, 34.28.184.105)
# On the VM:  cp .env.staging.example .env
#             then fill in every value marked REQUIRED
# Never commit .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Database — copy from ~/mysql/.env on the VM ───────────────────────────────
MYSQL_PASSWORD=                          # REQUIRED — MYSQL_PASSWORD in ~/mysql/.env

# ── Redis — copy from ~/redis/.env on the VM ─────────────────────────────────
REDIS_PASSWORD=                          # REQUIRED — REDIS_PASSWORD in ~/redis/.env

# ── Backend ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://staging.neurowatt.services

JWT_SECRET=                              # REQUIRED — generate: openssl rand -hex 32

XDC_RPC_URL=wss://ws.apothem.network
XDC_CHAIN_ID=51
XDC_INDEXER_START_BLOCK=80801637

# !! PRIVATE KEY — set ONLY on the VM, never commit a real value !!
# After first deploy, update .env on the VM and run:
#   docker compose -f docker-compose.staging.yml restart backend
VERIFLOW_SIGNER_PRIVATE_KEY=0x

# Contract proxy addresses (Apothem testnet)
WATT_USD_PROXY_ADDRESS=0x974B2bd650c88D290469a471DeB1Ee6aC55AD2d9
SWATT_USD_PROXY_ADDRESS=0x08c14aCc5547f03fC523453e005A243C50A7aa94
MINT_ENGINE_PROXY_ADDRESS=0x37a1d3b072af3055993215DB82e3832dA2d10AEd
ASSET_REGISTRY_PROXY_ADDRESS=0x
OCNFT_PROXY_ADDRESS=0x
HEALTH_ATTESTATION_PROXY_ADDRESS=0x
LENDING_POOL_PROXY_ADDRESS=0x
WEV_QUEUE_PROXY_ADDRESS=0x

BITGO_API_KEY=
PINATA_API_KEY=
KYC_PROVIDER_API_KEY=

# ── Frontend build args (baked into static bundle at build time) ──────────────
# VITE_API_URL: leave empty — nginx inside the frontend container proxies
# /api/... requests to the backend container. No cross-origin issues.
VITE_CHAIN_ID=51
VITE_RPC_URL=https://erpc.apothem.network
VITE_API_URL=
VITE_WALLETCONNECT_PROJECT_ID=b56e18d47c72ab683b10814fe9495694

VITE_WATT_ADDRESS=0x974B2bd650c88D290469a471DeB1Ee6aC55AD2d9
VITE_SWATT_ADDRESS=0x08c14aCc5547f03fC523453e005A243C50A7aa94
VITE_MINT_ENGINE_ADDRESS=0x37a1d3b072af3055993215DB82e3832dA2d10AEd
VITE_LENDING_POOL_ADDRESS=0x
VITE_WEV_QUEUE_ADDRESS=0x
VITE_USDC_ADDRESS=0x6404e052B842fB1c82C1A404C7E02BE2A92A7970
VITE_USDT_ADDRESS=0x59828572B8ABEDa2A0f963ECC94b80Eee01bbA6c
