# backend/.env.example
# Copy to backend/.env and fill in real values. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development       # development | staging | production | test

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for local dev only.
ALLOWED_ORIGINS=*

# ── Database (MySQL 8) ────────────────────────────────────────────────────────
DATABASE_URL=mysql://aiwatt:aiwatt@localhost:3306/aiwatt?parseTime=true

# ── Cache (Redis 7) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── XDC Network ───────────────────────────────────────────────────────────────
XDC_RPC_URL=https://erpc.apothem.network   # Apothem testnet
# XDC_RPC_URL=https://rpc.xdcrpc.com       # XDC mainnet
XDC_CHAIN_ID=51                            # 51 = Apothem, 50 = XDC mainnet

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# ── Veriflow ──────────────────────────────────────────────────────────────────
# Hot-wallet private key — must hold VERIFLOW_SIGNER role on HealthAttestation.sol.
# Leave as 0x (or unset) to disable on-chain writes in local dev / CI.
VERIFLOW_SIGNER_PRIVATE_KEY=0x

# ── Contract proxy addresses ──────────────────────────────────────────────────
# Run `make deploy-contracts-local` then paste the printed proxy addresses here.
# Apothem staging values are pre-filled where known; replace for local / mainnet.
WATT_USD_PROXY_ADDRESS=0x974B2bd650c88D290469a471DeB1Ee6aC55AD2d9
SWATT_USD_PROXY_ADDRESS=0x08c14aCc5547f03fC523453e005A243C50A7aa94
MINT_ENGINE_PROXY_ADDRESS=0x37a1d3b072af3055993215DB82e3832dA2d10AEd
ASSET_REGISTRY_PROXY_ADDRESS=0x
OCNFT_PROXY_ADDRESS=0x
HEALTH_ATTESTATION_PROXY_ADDRESS=0x
LENDING_POOL_PROXY_ADDRESS=0x
WEV_QUEUE_PROXY_ADDRESS=0x

# ── External integrations (optional) ─────────────────────────────────────────
BITGO_API_KEY=
PINATA_API_KEY=
KYC_PROVIDER_API_KEY=
