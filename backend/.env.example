# backend/.env.example
# Copy to backend/.env and fill in real values. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development       # development | production

# ── Database (MySQL 8) ────────────────────────────────────────────────────────
DATABASE_URL=mysql://aiwatt:aiwatt@localhost:3306/aiwatt?parseTime=true

# ── Cache (Redis 7) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── XDC Network ───────────────────────────────────────────────────────────────
XDC_RPC_URL=https://erpc.apothem.network
# XDC_RPC_URL=https://rpc.xdcrpc.com         # mainnet

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# ── Veriflow ──────────────────────────────────────────────────────────────────
# Private key for the backend signer wallet — writes attestations to XDC
VERIFLOW_SIGNER_PRIVATE_KEY=0x

# ── External integrations ─────────────────────────────────────────────────────
BITGO_API_KEY=
PINATA_API_KEY=
KYC_PROVIDER_API_KEY=
