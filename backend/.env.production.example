# Copy to .env.production and fill in secrets. Never commit .env.production.
# On the production VPS this file lives at /opt/aiwatt/production.env
PORT=8080
APP_ENV=production
ALLOWED_ORIGINS="https://aiwatt.io"

DATABASE_URL="mysql://aiwatt:CHANGE_ME@your-prod-db-host:3306/aiwatt?parseTime=true"
REDIS_URL="redis://your-prod-redis-host:6379/0"

XDC_RPC_URL="https://rpc.xdcrpc.com"
XDC_CHAIN_ID=50

JWT_SECRET="CHANGE_ME_min_32_chars"

VERIFLOW_SIGNER_PRIVATE_KEY="0x"

WATT_USD_PROXY_ADDRESS=
SWATT_USD_PROXY_ADDRESS=
MINT_ENGINE_PROXY_ADDRESS=
ASSET_REGISTRY_PROXY_ADDRESS=
OCNFT_PROXY_ADDRESS=
HEALTH_ATTESTATION_PROXY_ADDRESS=
LENDING_POOL_PROXY_ADDRESS=
WEV_QUEUE_PROXY_ADDRESS=

BITGO_API_KEY=
PINATA_API_KEY=
KYC_PROVIDER_API_KEY=
