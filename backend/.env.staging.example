# Copy to .env.staging and fill in secrets. Never commit .env.staging.
PORT=8080
APP_ENV=staging
ALLOWED_ORIGINS="https://staging.aiwatt.io"

DATABASE_URL="mysql://aiwatt:CHANGE_ME@your-staging-db-host:3306/aiwatt?parseTime=true"
REDIS_URL="redis://your-staging-redis-host:6379/0"

XDC_RPC_URL="wss://ews.apothem.network"
XDC_CHAIN_ID=51
XDC_INDEXER_START_BLOCK=0  # Set to your contract deployment block to skip old history

JWT_SECRET="CHANGE_ME_min_32_chars"

VERIFLOW_SIGNER_PRIVATE_KEY="0x"

WATT_USD_PROXY_ADDRESS="0x974B2bd650c88D290469a471DeB1Ee6aC55AD2d9"
SWATT_USD_PROXY_ADDRESS="0x08c14aCc5547f03fC523453e005A243C50A7aa94"
MINT_ENGINE_PROXY_ADDRESS="0x37a1d3b072af3055993215DB82e3832dA2d10AEd"
ASSET_REGISTRY_PROXY_ADDRESS="0x"
OCNFT_PROXY_ADDRESS="0x"
HEALTH_ATTESTATION_PROXY_ADDRESS="0x"
LENDING_POOL_PROXY_ADDRESS="0x"
WEV_QUEUE_PROXY_ADDRESS="0x"

BITGO_API_KEY=
PINATA_API_KEY=
KYC_PROVIDER_API_KEY=
