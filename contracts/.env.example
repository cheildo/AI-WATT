# contracts/.env.example
# Copy to contracts/.env and fill in real values. Never commit .env.

# ── Deployer ──────────────────────────────────────────────────────────────────
# Private key of the account that will deploy contracts.
# Fund with testnet XDC from https://faucet.apothem.network
DEPLOYER_PRIVATE_KEY=0x

# ── Network ───────────────────────────────────────────────────────────────────
# Override default RPC if needed (defaults are set in hardhat.config.ts)
# XDC_RPC_URL=https://erpc.apothem.network

# ── Phase 1 deploy inputs ─────────────────────────────────────────────────────
TREASURY_ADDRESS=0x        # Address that receives protocol fees
USDC_ADDRESS=0x            # USDC token address on target network
USDT_ADDRESS=0x            # USDT token address on target network (optional)
