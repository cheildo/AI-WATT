# frontend/.env.example
# Copy to .env.local and fill in values. Never commit .env.local.

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080

# ── XDC Network ───────────────────────────────────────────────────────────────
VITE_XDC_RPC_URL=https://erpc.apothem.network
VITE_CHAIN_ID=51

# ── Contracts (update after each deploy) ──────────────────────────────────────
VITE_WATT_ADDRESS=0x
VITE_SWATT_ADDRESS=0x
VITE_MINT_ENGINE_ADDRESS=0x
VITE_LENDING_POOL_ADDRESS=0x
VITE_WEV_QUEUE_ADDRESS=0x
