# frontend/.env.example
# Copy to frontend/.env.local and fill in values. Never commit .env.local.

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080

# ── XDC Network ───────────────────────────────────────────────────────────────
VITE_XDC_RPC_URL=https://erpc.apothem.network
VITE_CHAIN_ID=51                        # 51 = Apothem testnet, 50 = XDC mainnet

# ── Contracts (update after each deploy) ──────────────────────────────────────
VITE_WATT_USD_ADDRESS=0x
VITE_MINT_ENGINE_ADDRESS=0x
