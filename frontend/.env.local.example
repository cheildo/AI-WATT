# ── Local development (Hardhat node) ────────────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local

VITE_ENV=local
VITE_CHAIN_ID=31337
VITE_RPC_URL=http://localhost:8545
VITE_API_URL=http://localhost:8080

# Get a free WalletConnect project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=demo

# Stablecoin addresses — printed by `npx hardhat run scripts/deploy-mocks.ts`
VITE_USDC_ADDRESS=
VITE_USDT_ADDRESS=

# Protocol proxy addresses — printed by `make deploy-contracts-local`
VITE_WATT_ADDRESS=
VITE_SWATT_ADDRESS=
VITE_MINT_ENGINE_ADDRESS=
VITE_LENDING_POOL_ADDRESS=
VITE_WEV_QUEUE_ADDRESS=
