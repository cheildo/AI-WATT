# ── Production (XDC Mainnet, chainId 50) ────────────────────────────────────
# These values are injected as GitHub secrets in deploy-production.yml.
# Do NOT commit a populated .env.production file.

VITE_ENV=production
VITE_CHAIN_ID=50
VITE_RPC_URL=https://rpc.xdcrpc.com
VITE_API_URL=https://api.aiwatt.io

VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Real stablecoin addresses on XDC mainnet
VITE_USDC_ADDRESS=
VITE_USDT_ADDRESS=

# Fill after mainnet contract deploy — add to GitHub secrets as PROD_*
VITE_WATT_ADDRESS=
VITE_SWATT_ADDRESS=
VITE_MINT_ENGINE_ADDRESS=
VITE_LENDING_POOL_ADDRESS=
VITE_WEV_QUEUE_ADDRESS=
