# veriflow-agent/.env.example
# Copy to veriflow-agent/.env (or configure as systemd EnvironmentFile).
# Never commit .env.

# ── Agent identity ────────────────────────────────────────────────────────────
# UUID of the hardware asset this agent monitors — assigned during onboarding
ASSET_ID=

# Shared HMAC-SHA256 key between this agent and the backend — 32+ random bytes
HMAC_KEY=

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_URL=https://api.aiwatt.io
